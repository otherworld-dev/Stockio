# Stockio Configuration
# Copy this file to .env and fill in your values

# Initial budget in GBP
STOCKIO_BUDGET=500.00

# Trading mode: "paper" (simulated) or "live"
STOCKIO_MODE=paper

# Alpaca API credentials (only needed for live trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ---------------------------------------------------------------------------
# News feeds
# ---------------------------------------------------------------------------
# Extra RSS feeds to scan (comma-separated). These are IN ADDITION to the
# built-in feeds (BBC Business, Guardian, Yahoo Finance indices, etc.).
# Leave empty to use only the built-in feeds.
STOCKIO_NEWS_FEEDS=

# ---------------------------------------------------------------------------
# Markets — which exchanges to scan for stocks
# ---------------------------------------------------------------------------
# Supported: LSE, AIM, NYSE, NASDAQ, EURONEXT, XETRA
# Default targets UK markets primarily + major global exchanges.
# The bot scans ALL stocks on each exchange, including penny stocks.
STOCKIO_MARKETS=LSE,AIM,NYSE,NASDAQ

# Extra tickers to always include (on top of market discovery)
# Leave empty to rely purely on market discovery
STOCKIO_WATCHLIST=

# How often to refresh the full ticker list from each market (hours)
STOCKIO_MARKET_REFRESH_HOURS=24

# How many tickers to analyse per trading cycle (rotates through all)
STOCKIO_BATCH_SIZE=50

# Include penny stocks in discovery (true/false)
STOCKIO_INCLUDE_PENNY_STOCKS=true

# Max tickers to discover per market (safety limit)
STOCKIO_MAX_TICKERS_PER_MARKET=5000

# ---------------------------------------------------------------------------
# Scheduling
# ---------------------------------------------------------------------------

# How often to run the trading loop (in minutes)
STOCKIO_INTERVAL_MINUTES=30

# ML model retraining frequency (in hours)
STOCKIO_RETRAIN_HOURS=24

# ---------------------------------------------------------------------------
# Risk management
# ---------------------------------------------------------------------------
STOCKIO_MAX_POSITION_PCT=20
STOCKIO_STOP_LOSS_PCT=5
STOCKIO_TAKE_PROFIT_PCT=15

# Logging level
STOCKIO_LOG_LEVEL=INFO
