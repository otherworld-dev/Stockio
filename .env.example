# Stockio Configuration
# Copy this file to .env and fill in your values

# Initial budget in GBP
STOCKIO_BUDGET=500.00

# Trading mode: "paper" (simulated) or "live"
STOCKIO_MODE=paper

# Alpaca API credentials (only needed for live trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ---------------------------------------------------------------------------
# News feeds
# ---------------------------------------------------------------------------
# Extra RSS feeds to scan (comma-separated). These are IN ADDITION to the
# built-in feeds (BBC Business, Guardian, Yahoo Finance indices, etc.).
# Leave empty to use only the built-in feeds.
STOCKIO_NEWS_FEEDS=

# ---------------------------------------------------------------------------
# Markets — which exchanges to scan for stocks
# ---------------------------------------------------------------------------
# Supported: LSE, AIM, NYSE, NASDAQ, EURONEXT, XETRA
# Default targets UK markets primarily + major global exchanges.
# The bot scans ALL stocks on each exchange, including penny stocks.
STOCKIO_MARKETS=LSE,AIM,NYSE,NASDAQ

# Extra tickers to always include (on top of market discovery)
# Leave empty to rely purely on market discovery
STOCKIO_WATCHLIST=

# How often to refresh the full ticker list from each market (hours)
STOCKIO_MARKET_REFRESH_HOURS=24

# How many tickers to analyse per trading cycle (rotates through all)
STOCKIO_BATCH_SIZE=50

# Include penny stocks in discovery (true/false)
STOCKIO_INCLUDE_PENNY_STOCKS=true

# Max tickers to discover per market (safety limit)
STOCKIO_MAX_TICKERS_PER_MARKET=5000

# ---------------------------------------------------------------------------
# Reddit / Social media
# ---------------------------------------------------------------------------

# Enable/disable Reddit monitoring (true/false)
STOCKIO_REDDIT_ENABLED=true

# Subreddits to monitor for stock discussion (comma-separated)
STOCKIO_SUBREDDITS=wallstreetbets,stocks,investing,UKInvesting,pennystocks,StockMarket

# Max posts to fetch per subreddit each cycle
STOCKIO_REDDIT_MAX_POSTS=25

# How much weight Reddit sentiment gets vs traditional news (0.0-1.0)
# Lower = less influence, higher = more influence
STOCKIO_REDDIT_WEIGHT=0.3

# ---------------------------------------------------------------------------
# Trump / Political monitoring
# ---------------------------------------------------------------------------

# Enable monitoring of Trump's Truth Social, White House actions, and
# political news that tends to move markets (tariffs, executive orders, etc.)
STOCKIO_TRUMP_MONITORING=true

# Weight multiplier for Trump/political stories (default 1.5x)
# These events often cause immediate, outsized market moves so they get
# extra influence on sentiment scoring
STOCKIO_TRUMP_WEIGHT=1.5

# ---------------------------------------------------------------------------
# Scheduling
# ---------------------------------------------------------------------------

# How often to run the trading loop (in minutes)
STOCKIO_INTERVAL_MINUTES=30

# ML model retraining frequency (in hours)
STOCKIO_RETRAIN_HOURS=24

# ---------------------------------------------------------------------------
# Risk management — long positions
# ---------------------------------------------------------------------------
STOCKIO_MAX_POSITION_PCT=20
STOCKIO_STOP_LOSS_PCT=5
STOCKIO_TAKE_PROFIT_PCT=15

# ---------------------------------------------------------------------------
# Risk management — short selling (betting against stocks)
# ---------------------------------------------------------------------------
# Enable/disable short selling entirely
STOCKIO_SHORT_SELLING=true

# Max % of portfolio value for a single short position (kept lower than longs
# because shorts carry more risk — losses are theoretically unlimited)
STOCKIO_MAX_SHORT_POSITION_PCT=15

# Stop-loss for shorts: auto-cover if price rises this % above entry
STOCKIO_SHORT_STOP_LOSS_PCT=5

# Take-profit for shorts: auto-cover if price drops this % below entry
STOCKIO_SHORT_TAKE_PROFIT_PCT=10

# Max total short exposure as % of portfolio (caps all shorts combined)
STOCKIO_MAX_TOTAL_SHORT_PCT=30

# Logging level
STOCKIO_LOG_LEVEL=INFO
